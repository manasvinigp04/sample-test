# Environment Configuration
ENV=local  # local, docker, staging, production

# Service Feature Flags
USER_SERVICE_ENABLED=true
PRODUCT_SERVICE_ENABLED=true
ORDER_SERVICE_ENABLED=true
PAYMENT_SERVICE_ENABLED=true

# Feature Flags
ENABLE_REDIS_CACHE=true
ENABLE_RATE_LIMITING=true
ENABLE_METRICS=false
ENABLE_SWAGGER_UI=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./ecommerce.db

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# JWT Authentication
# IMPORTANT: Change this in production!
JWT_SECRET_KEY=your-secret-key-change-in-production-PLEASE
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Logging
LOG_LEVEL=INFO
